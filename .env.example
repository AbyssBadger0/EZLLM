# Optional EZLLM environment overrides.
# Copy to .env for your own shell tooling if desired. EZLLM does not load this
# file automatically.

EZLLM_CONFIG=/path/to/config.toml
EZLLM_SERVER_BIN=/path/to/llama-server
EZLLM_MODEL_PATH=/path/to/model.gguf
EZLLM_MMPROJ_PATH=/path/to/mmproj.gguf
EZLLM_CTX_SIZE=65536
EZLLM_N_PREDICT=16384
EZLLM_REASONING=auto
